---
import CaseStudiesGrid from "@components/CaseStudies/CaseStudiesGrid.astro";
import CtaUku from "@components/Cta/CtaUku.astro";
import Benefits from "@components/Feature/Benefits.astro";
import FeatureGridUku from "@components/Feature/FeatureGridUku.astro";
import Languages from "@components/Feature/Languages.astro";
import OnboardingSteps from "@components/Feature/OnboardingSteps.astro";
import WhyUku from "@components/Feature/WhyUku.astro";
import HeroUkuMain from "@components/Hero/HeroUkuMain.astro";
import LogoCloudClients from "@components/LogoCloud/LogoCloudClients.astro";
import G2Showcase from "@components/Testimonials/G2Showcase.astro";
import SupportTestimonial from "@components/Testimonials/SupportTestimonial.astro";
import TestimonialsUku from "@components/Testimonials/TestimonialsUku.astro";
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";
import BaseLayout from "@layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title={siteData.title} description={siteData.description}>
  <HeroUkuMain />
  <LogoCloudClients />
  <TestimonialsUku />
  <WhyUku />
  <FeatureGridUku />
  <Benefits />
  <Languages />
  <OnboardingSteps />
  <SupportTestimonial />
  <G2Showcase />
  <CaseStudiesGrid />
  <CtaUku />
</BaseLayout>
