---
/**
 * * Stats section - Uku social proof numbers
 */

import FeatureCard from "@components/FeatureCard/FeatureCardColorText.astro";

interface FeatureCardData {
  icon: string;
  title: string;
  text: string;
}

const featureData: FeatureCardData[] = [
  {
    icon: "tabler/star",
    title: "9.5",
    text: "Ease of Use (G2)",
  },
  {
    icon: "tabler/headset",
    title: "9.7",
    text: "Quality of Support (G2)",
  },
  {
    icon: "tabler/rocket",
    title: "8.9",
    text: "Ease of Setup (G2)",
  },
  {
    icon: "tabler/world",
    title: "12",
    text: "Languages supported",
  },
];
---

<section id="feature5" class="my-24 md:my-36">
  <div class="site-container">
    <div class="mr-auto max-w-xl">
      <div class="flex">
        <p class="colored-title" data-mos="fade-up" data-mos-anchor="#feature5">
          Highly rated
        </p>
      </div>
      <h2 class="h2 mt-6" data-mos="fade-up" data-mos-delay=".1" data-mos-anchor="#feature5">
        Trusted by accounting firms worldwide
      </h2>
      <p
        class="text-base-700 dark:text-base-300 mt-4"
        data-mos="fade-up"
        data-mos-delay=".2"
        data-mos-anchor="#feature5"
      >
        Accounting firms across 30+ countries rely on Uku every day. Our users consistently rate us among the highest in the industry for usability, support, and value.
      </p>
    </div>

    <div id="feature5cards" class="xs:grid-cols-2 mt-8 grid gap-6 md:mt-16 md:grid-cols-4">
      {
        featureData.map((feature, idx) => (
          <FeatureCard
            title={feature.title}
            text={feature.text}
            icon={feature.icon}
            data-mos="fade-up"
            data-mos-delay={`${idx * 0.25 + 0.2}`}
            data-mos-anchor="#feature5cards"
          />
        ))
      }
    </div>
  </div>
</section>
