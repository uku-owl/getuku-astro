---
/**
 * * Alternating side cards - Uku feature highlights with screenshots
 */

import FeatureCard from "@components/FeatureCard/FeatureCardSideImage.astro";
import image1 from "@images/uku-task-management.png";
import image2 from "@images/uku-billing.png";
import image3 from "@images/uku-automation.png";

interface FeatureItem {
  image: ImageMetadata;
  label: string;
  title: string;
  details: string;
}

const featureData: FeatureItem[] = [
  {
    image: image1,
    label: "Task Management",
    title: "Your team is focused, productive & organized",
    details: `Assign tasks, set deadlines, and track progress in real time. Uku's smart task management ensures nothing falls through the cracks. Your team always knows what to work on next, and managers see the big picture at a glance.`,
  },
  {
    image: image2,
    label: "Automated Billing",
    title: "Your billing is simple & fast",
    details: `Generate invoices automatically from tracked time and fixed-fee contracts. Support for multiple billing models, recurring invoices, and payment tracking. Spend less time on admin, more time on advisory.`,
  },
  {
    image: image3,
    label: "Workflow Automation",
    title: "Your team saves ~30% of the time",
    details: `Automate recurring tasks, email notifications, and client reminders. Create reusable workflow templates that your entire team can follow. Work that used to take hours now happens automatically.`,
  },
];
---

<section id="feature4" class="my-24 overflow-clip md:my-36">
  <div class="site-container">
    <div class="flex flex-col gap-16 md:gap-24">
      {
        featureData.map((feature, idx) => (
          <FeatureCard
            label={feature.label}
            title={feature.title}
            details={feature.details}
            image={feature.image}
            imageSide={idx % 2 === 0 ? "right" : "left"}
          />
        ))
      }
    </div>
  </div>
</section>
