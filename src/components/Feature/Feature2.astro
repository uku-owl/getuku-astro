---
/**
 * * 3 benefit cards - key value propositions
 */

import FeatureCard from "@components/FeatureCard/FeatureCardLarge.astro";

interface FeatureData {
  icon: string;
  title: string;
  text: string;
}

const featureData: FeatureData[] = [
  {
    icon: "tabler/clock-check",
    title: "Save 12+ hours per team member weekly",
    text: "Automated workflows handle recurring tasks, reminders, and billing. Your team spends time on advisory, not admin.",
  },
  {
    icon: "tabler/trending-up",
    title: "Increase profit margins by 23.5%",
    text: "Time tracking and analytics reveal exactly where your firm makes (and loses) money. Price services with confidence.",
  },
  {
    icon: "tabler/settings-automation",
    title: "Set up in one week",
    text: "Automatic data import, reusable templates, and dedicated onboarding support. Start seeing results from day one.",
  },
];
---

<section id="feature2" class="my-12 md:my-24">
  <div class="site-container">
    <div class="mx-auto mb-8 max-w-xl text-center">
      <div class="flex justify-center">
        <p class="colored-title inline">Key Benefits</p>
      </div>
      <h2 class="h2 mt-4">Why accounting firms switch to Uku</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      {
        featureData.map((feature) => (
          <FeatureCard title={feature.title} text={feature.text} icon={feature.icon} />
        ))
      }
    </div>
  </div>
</section>
