---
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "CRM",
    description: "Customizable client profiles\nTasks & notes\nContacts",
    link: "/client-management",
  },
  {
    title: "Time-tracking",
    description: "Stopwatch & manual\nBulk time entry\nBrowser plugin",
    link: "/time-tracking",
  },
  {
    title: "Communication",
    description: "Messages\nComments\nEmails",
    link: "/team-collaboration",
  },
  {
    title: "Analysis",
    description: "Time reports\nSummary & detail\nClient agreement monitoring",
    link: "/business-analytics",
  },
  {
    title: "Automation",
    description: "Workflows\nInvoices\nEmails",
    link: "/workflow-automation",
  },
  {
    title: "Projects",
    description: "Tasks with dependencies\nProgress overview\nTemplates",
    link: "/accounting-project-management",
  },
  {
    title: "Billing",
    description: "Time, volume, fixed or recurring billing\nAutomated invoicing\nTemplates & pricelists",
    link: "/automated-billing",
  },
  {
    title: "Client Portal",
    description: "Client tasks & requests\nDocuments\nReminders",
    link: "/client-portal",
  },
  {
    title: "Integrations",
    description: "QuickBooks\nXero\nMicrosoft 365",
    link: "/integrations",
  },
];
---

<section id="features-grid" class="relative py-24 md:py-32">
  <div class="site-container">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-3xl text-center">
      <p
        class="text-secondary-600 dark:text-secondary-400 mb-3 text-sm font-semibold uppercase tracking-wider"
        data-mos="fade-up"
      >
        Accountancy Practice Management Software
      </p>
      <h2
        class="from-base-900 to-base-700 dark:from-base-50 dark:to-base-300 mb-4 bg-gradient-to-br bg-clip-text text-3xl font-bold text-transparent md:text-4xl"
        data-mos="fade-up"
        data-mos-delay="0.1"
      >
        Get Full Control of Your Accounting Firm
      </h2>
      <p
        class="text-base-700 dark:text-base-300"
        data-mos="fade-up"
        data-mos-delay="0.2"
      >
        Uku, the accounting practice management software, is powerful and easy to use at the same time.
      </p>
    </div>

    <!-- Features grid - minimalist -->
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, index) => (
          <a
            href={feature.link}
            class="hover:text-secondary-600 dark:hover:text-secondary-400 group transition-colors"
            data-mos="fade-up"
            data-mos-delay={0.05 * index}
          >
            <h3 class="text-base-900 dark:text-base-50 mb-3 text-xl font-semibold">
              {feature.title}
            </h3>
            <ul class="text-base-600 dark:text-base-400 space-y-1.5 text-sm leading-relaxed">
              {feature.description.split('\n').map((line) => (
                line.trim() && <li class="flex items-start gap-2">
                  <span class="text-secondary-600 dark:text-secondary-400 mt-0.5">•</span>
                  <span>{line.trim()}</span>
                </li>
              ))}
            </ul>
            <div class="text-secondary-600 dark:text-secondary-400 mt-4 inline-flex items-center gap-1 text-sm font-medium group-hover:gap-2 transition-all">
              <span>More ›</span>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Mission statement -->
    <div
      class="mx-auto mt-20 max-w-2xl text-center"
      data-mos="fade-up"
      data-mos-delay="0.8"
    >
      <p class="text-base-600 dark:text-base-400 text-sm font-medium">
        Uku's mission
      </p>
      <p class="mt-2 text-4xl font-bold md:text-5xl">
        <span class="from-secondary-600 to-secondary-800 dark:from-secondary-400 dark:to-secondary-600 bg-gradient-to-r bg-clip-text text-transparent">Freedom</span>
        {' '}to do{' '}
        <span class="from-accent to-amber-500 dark:from-accent dark:to-amber-400 bg-gradient-to-r bg-clip-text text-transparent">less</span>
      </p>
    </div>
  </div>
</section>
