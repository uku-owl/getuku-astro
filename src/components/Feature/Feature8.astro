---
/**
 * * "Why Uku" toggleable image section - Selection text on left, screenshots on right
 */
import image1 from "@images/uku-task-management.png";
import image2 from "@images/uku-billing.png";
import image3 from "@images/uku-analytics.png";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

interface ToggleSection {
  icon: string;
  title: string;
  description: string;
  image: ImageMetadata;
}

interface FeatureData {
  label: string;
  title: string;
  toggleSections: ToggleSection[];
}

const featureData: FeatureData = {
  label: "Why Uku",
  title: "Everything your accounting firm needs in one place",
  toggleSections: [
    {
      icon: "tabler/list-check",
      title: "Your team is focused, productive & organized",
      description: "Smart task management with deadlines, assignments, and real-time progress tracking.",
      image: image1,
    },
    {
      icon: "tabler/receipt",
      title: "Your billing is simple & fast",
      description: "Automated invoice generation from tracked time and fixed-fee contracts.",
      image: image2,
    },
    {
      icon: "tabler/chart-bar",
      title: "You have full visibility to grow",
      description: "Time-tracking analytics for better pricing decisions and profitability insights.",
      image: image3,
    },
  ],
};
---

<section id="feature8" class="my-24 md:my-36">
  <div class="site-container">
    <div class="mx-auto grid gap-8 rounded-2xl md:grid-cols-5 lg:gap-12">
      <div class="md:col-span-2" data-mos="fade-up">
        <div class="flex">
          <p class="colored-title">{featureData.label}</p>
        </div>
        <h2 class="h2 mt-6">{featureData.title}</h2>
        <div class="mt-6 flex flex-col gap-2">
          {
            featureData.toggleSections.map((section, idx) => (
              <button
                id={`feature8__toggle-${idx}`}
                class={`${
                  idx === 0 ? "feature8__toggle--active" : ""
                } hover:primary-300 border-base-300 hover:border-primary-300 dark:border-base-600/60 dark:hover:border-base-500 flex flex-col items-start justify-start gap-1 rounded-md border p-3 opacity-90 transition duration-300 hover:opacity-100 dark:opacity-80`}
              >
                <div class="flex items-center gap-2">
                  <Icon name={section.icon} class="h-5 w-5" aria-hidden="true" />
                  <p class="text-start text-lg font-medium">{section.title}</p>
                </div>
                <p class="text-base-500 text-start text-sm">{section.description}</p>
              </button>
            ))
          }
        </div>
      </div>

      <!-- image -->
      <div class="mx-auto mb-auto max-w-4xl md:col-span-3" data-mos="fade-left">
        <div
          class=`relative h-full overflow-hidden rounded-2xl bg-gradient-to-br from-primary-400 via-base-300/70 to-base-300/70
          dark:from-primary-500 dark:via-base-600/60 dark:to-base-600/60
            after:absolute after:rounded-[calc(1rem-1px)] after:bg-base-100/30 dark:after:bg-base-800/50 after:inset-[1px]`
        >
          {
            featureData.toggleSections.map((section, idx) => (
              <Image
                id={`feature8__image-${idx}`}
                class={`${
                  idx === 0 ? "" : "hidden"
                } relative z-10 rounded-2xl border border-transparent object-cover p-1`}
                src={section.image}
                alt={section.title}
                width={1200}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import "tailwindcss/theme" theme(reference);
  @import "@/styles/tailwind-theme.css" theme(reference);

  .feature8__toggle--active {
    @apply border-primary-300 ring-primary-500 dark:border-base-500 opacity-100 ring-1;
  }
</style>

<script>
  function toggleFeatureSetup() {
    const toggleButtons = document.querySelectorAll(
      "[id^=feature8__toggle-]",
    ) as NodeListOf<HTMLButtonElement>;
    const toggleImages = document.querySelectorAll(
      "[id^=feature8__image-]",
    ) as NodeListOf<HTMLImageElement>;

    toggleButtons?.forEach((button, idx) => {
      button.addEventListener("click", () => {
        toggleButtons?.forEach((button) => {
          button.classList.remove("feature8__toggle--active");
        });
        button.classList.add("feature8__toggle--active");
        toggleImages.forEach((image) => {
          image.classList.add("hidden");
        });
        toggleImages[idx]?.classList.remove("hidden");
      });
    });
  }

  toggleFeatureSetup();
  document.addEventListener("astro:after-swap", toggleFeatureSetup);
</script>
