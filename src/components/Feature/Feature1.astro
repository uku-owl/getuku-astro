---
/**
 * * Uku feature grid - 9 core modules
 */

import FeatureCard from "@components/FeatureCard/FeatureCardSmall.astro";

interface FeatureData {
  icon: string;
  title: string;
  text: string;
}

const featureData: FeatureData[] = [
  {
    icon: "tabler/users",
    title: "CRM",
    text: "Customizable client profiles with tasks, notes, contacts, and full communication history.",
  },
  {
    icon: "tabler/clock",
    title: "Time Tracking",
    text: "Stopwatch, manual entry, and browser plugin. Track every billable minute effortlessly.",
  },
  {
    icon: "tabler/mail",
    title: "Communication",
    text: "Messages, comments, and email integration. Keep all client communication in one place.",
  },
  {
    icon: "tabler/chart-pie",
    title: "Analysis",
    text: "Time reports and client agreement monitoring. Make data-driven pricing decisions.",
  },
  {
    icon: "tabler/robot",
    title: "Automation",
    text: "Recurring workflows, automated invoices, and email notifications. Save 30% of your time.",
  },
  {
    icon: "tabler/subtask",
    title: "Projects",
    text: "Task dependencies, progress overview, and reusable templates for every engagement.",
  },
  {
    icon: "tabler/receipt",
    title: "Billing",
    text: "Multiple billing models, automated invoicing, and payment tracking in one system.",
  },
  {
    icon: "tabler/device-laptop",
    title: "Client Portal",
    text: "Tasks, documents, and reminders. Give clients a professional self-service experience.",
  },
  {
    icon: "tabler/plug",
    title: "Integrations",
    text: "QuickBooks, Xero, Microsoft 365, and more. Connect the tools you already use.",
  },
];
---

<section id="feature1" class="my-12 md:my-24">
  <div class="site-container">
    <div class="mx-auto mb-8 max-w-xl text-center">
      <div class="flex justify-center">
        <p class="colored-title inline">Full Control</p>
      </div>
      <h2 class="h2 mt-4">Get full control of your accounting firm</h2>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 md:py-8 lg:grid-cols-3">
      {
        featureData.map((feature, idx) => (
          <FeatureCard
            title={feature.title}
            text={feature.text}
            icon={feature.icon}
            data-mos="fade-up"
            data-mos-delay={0.1 * idx}
            data-mos-anchor="#feature1"
          />
        ))
      }
    </div>
  </div>
</section>
