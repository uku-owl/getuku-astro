---
/**
 * * Logo cloud section - Uku client logos
 */
---

<section
  id="logocloud1"
  class="border-base-300 dark:border-base-600/60 flex items-end justify-center border-y py-6"
>
  <div class="site-container">
    <div class="mx-auto max-w-xl">
      <div class="flex justify-center">
        <h2 class="colored-title inline">Trusted by leading accounting firms</h2>
      </div>
    </div>
    <div class="mt-6">
      <div class="grid w-full grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-8 items-center">
        <div class="flex justify-center px-4">
          <img src="/images/clients/leinonen.png" alt="Leinonen" class="logo" loading="lazy" />
        </div>
        <div class="flex justify-center px-4">
          <img src="/images/clients/bakertilly.png" alt="Baker Tilly" class="logo" loading="lazy" />
        </div>
        <div class="flex justify-center px-4">
          <img src="/images/clients/sandgrav.png" alt="Sandgrav Solutions" class="logo" loading="lazy" />
        </div>
        <div class="flex justify-center px-4">
          <img src="/images/clients/grow.svg" alt="Grow" class="logo" loading="lazy" />
        </div>
        <div class="flex justify-center px-4">
          <img src="/images/clients/numeri.svg" alt="Numeri" class="logo" loading="lazy" />
        </div>
        <div class="flex justify-center px-4">
          <img src="/images/clients/chk.svg" alt="CHK" class="logo" loading="lazy" />
        </div>
        <div class="flex justify-center px-4">
          <img src="/images/clients/robby-bobby.png" alt="Robby & Bobby" class="logo" loading="lazy" />
        </div>
        <div class="flex justify-center px-4">
          <img src="/images/clients/1office.svg" alt="1office" class="logo" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import "tailwindcss/theme" theme(reference);
  @import "@/styles/tailwind-theme.css" theme(reference);

  .logo {
    @apply mx-auto h-10 w-auto max-w-[100px] object-contain opacity-70 transition hover:opacity-100;
  }
</style>
