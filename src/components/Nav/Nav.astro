---
import Button from "@components/Button/Button.astro";
import LanguageSelect from "@components/LanguageSelect/LanguageSelect.astro";
import MobileNav from "@components/Nav/MobileNav/MobileNav.astro";
import MegaMenuDropdownToggle from "@components/Nav/NavDropdown/MegaMenuDropdownToggle.astro";
import NavDropdownToggle from "@components/Nav/NavDropdown/NavDropdownToggle.astro";
import NavLink from "@components/Nav/NavLink.astro";
import ProductMegaMenu from "@components/Nav/ProductMegaMenu.astro";
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import ThemeToggle from "@components/ThemeToggle/ThemeToggle.astro";
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

import { locales } from "@config/siteSettings.json";

const currLocale = getLocaleFromUrl(Astro.url);
const navData = getTranslatedData("navData", currLocale);

// Filter out "Product" from navData - we handle it separately with ProductMegaMenu
const otherNavItems = navData.filter((item: any) => {
  const text = "text" in item ? item.text : "";
  return text !== "Product";
});
---

<section
  id="nav"
  class="navbar--initial fixed top-0 left-0 z-30 flex w-full flex-col transition-all duration-300"
>
  <div class="mx-auto flex w-full max-w-7xl px-4">
    <div class="flex w-full items-center py-3">
      <header class="relative flex w-full items-center">
        <!-- Logo -->
        <div class="flex-shrink-0">
          <SiteLogo />
        </div>

        <!-- Left-aligned navigation -->
        <nav class="ml-6 hidden lg:block">
          <ul class="flex items-center gap-0">
            {/* Product mega menu (custom component) */}
            <ProductMegaMenu />

            {/* Other nav items */}
            {
              otherNavItems.map((navItem: any) =>
                "megaMenuColumns" in navItem ? (
                  <MegaMenuDropdownToggle navItem={navItem} />
                ) : "dropdown" in navItem ? (
                  <NavDropdownToggle navItem={navItem} />
                ) : (
                  <NavLink navItem={navItem} />
                ),
              )
            }

            {/* Language selector inline with nav */}
            {locales.length > 1 && <LanguageSelect class="ml-1" />}
          </ul>
        </nav>

        <!-- Right side: Log in + DEMO + Try for FREE -->
        <div class="ml-auto flex items-center gap-2">
          <ThemeToggle class="hidden lg:flex" />

          <a
            href="https://app.getuku.com/"
            class="nav__link--base hidden px-3 py-1.5 text-sm whitespace-nowrap lg:block"
          >
            Log in
          </a>

          <a
            href="/book-demo"
            class="border-base-800 dark:border-base-200 hidden rounded-3xl border px-4 py-1.5 text-sm font-semibold whitespace-nowrap transition hover:bg-base-200 dark:hover:bg-base-800 lg:block"
          >
            DEMO
          </a>

          <a
            href="https://app.getuku.com/register"
            class="bg-royal-blue-500 hover:bg-royal-blue-600 hidden rounded-3xl px-5 py-2 text-sm font-semibold whitespace-nowrap text-white lg:block"
          >
            Try for FREE
          </a>

          <!-- Mobile menu toggle -->
          <div class="flex items-center lg:hidden">
            <MobileNav />
          </div>
        </div>
      </header>
    </div>
  </div>
</section>

<style>
  @import "tailwindcss/theme" theme(reference);
  @import "@/styles/tailwind-theme.css" theme(reference);

  .navbar--scrolled {
    @apply border-foreground/10 bg-background/30 backdrop-blur;
  }

  .navbar--initial {
    @apply border-b-transparent bg-transparent;
  }
</style>

<script>
  let navbar: HTMLElement | null;

  function scrollHandler() {
    if (navbar) {
      if (window.scrollY > 50) {
        navbar.classList.add("navbar--scrolled");
        navbar.classList.remove("navbar--initial");
      } else {
        navbar.classList.add("navbar--initial");
        navbar.classList.remove("navbar--scrolled");
      }
    }
  }

  function initNav() {
    navbar = document.getElementById("nav");
    window.addEventListener("scroll", scrollHandler, { passive: true });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>
