---
import Button from "@components/Button/Button.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import heroDashboard from "@images/hero-dashboard.png";
---

<section id="hero-main" class="relative flex w-full overflow-hidden pt-24 pb-20 md:pt-32 md:pb-28">
  <!-- Glow effect (no grid) -->
  <div
    class="bg-secondary-500/20 dark:bg-secondary-400/10 absolute inset-0 top-[60%] -z-10 mx-auto h-[40%] w-[60%] max-w-4xl rounded-full blur-[120px]"
    aria-hidden="true"
  >
  </div>

  <!-- hero content -->
  <div class="site-container mx-auto max-w-6xl gap-8 pb-32 text-center sm:pb-44 md:pb-72">
    <!-- Small label at top -->
    <p
      class="text-secondary-600 dark:text-secondary-400 mb-4 text-xs font-semibold uppercase tracking-wider md:text-sm"
      data-mos="fade-up"
    >
      Accounting Practice Management Software
    </p>

    <!-- Main headline - smaller size -->
    <h1
      class="from-base-900 to-base-700 dark:from-base-100 dark:to-base-400 bg-gradient-to-r bg-clip-text pb-2 text-4xl font-bold text-transparent md:text-5xl lg:text-6xl"
      data-mos="fade-up"
      data-mos-delay="0.1"
      data-mos-anchor="#hero-main"
    >
      Get work done on time,<br />billed & paid
    </h1>
    
    <!-- Subheadline -->
    <p
      class="text-base-700 dark:text-base-300 mx-auto mt-4 max-w-2xl text-base md:text-lg"
      data-mos="fade-up"
      data-mos-delay="0.2"
      data-mos-anchor="#hero-main"
    >
      With Uku, accounting firms save over <strong>12 hours per team member weekly</strong> and raise profit <strong>23.5%</strong> with powerful billing.
    </p>

    <!-- No credit card text -->
    <p
      class="text-base-600 dark:text-base-400 mt-3 text-sm"
      data-mos="fade-up"
      data-mos-delay="0.3"
      data-mos-anchor="#hero-main"
    >
      No credit card required.
    </p>

    <!-- Social proof badges inline -->
    <div
      class="mt-4 flex flex-wrap items-center justify-center gap-4"
      data-mos="fade-up"
      data-mos-delay="0.4"
      data-mos-anchor="#hero-main"
    >
      <a href="https://www.g2.com/products/uku/reviews" target="_blank" rel="noopener" class="flex items-center gap-2 transition hover:opacity-80">
        <div class="flex">
          {[...Array(5)].map(() => (
            <Icon name="tabler/star-filled" class="text-accent h-4 w-4" aria-hidden="true" />
          ))}
        </div>
        <span class="text-base-600 dark:text-base-400 text-sm font-medium">4.7</span>
      </a>
      <a href="https://www.capterra.com/p/197626/Uku/" target="_blank" rel="noopener" class="flex items-center gap-2 transition hover:opacity-80">
        <div class="flex">
          {[...Array(5)].map(() => (
            <Icon name="tabler/star-filled" class="text-accent h-4 w-4" aria-hidden="true" />
          ))}
        </div>
        <span class="text-base-600 dark:text-base-400 text-sm font-medium">4.8</span>
      </a>
      <a href="https://www.getapp.com/industries-software/a/uku/" target="_blank" rel="noopener" class="flex items-center gap-2 transition hover:opacity-80">
        <div class="flex">
          {[...Array(5)].map(() => (
            <Icon name="tabler/star-filled" class="text-accent h-4 w-4" aria-hidden="true" />
          ))}
        </div>
        <span class="text-base-600 dark:text-base-400 text-sm font-medium">4.8</span>
      </a>
    </div>

    <!-- CTA buttons - horizontal layout -->
    <div
      class="mx-auto mt-8 flex max-w-md flex-wrap items-center justify-center gap-4"
      data-mos="fade-up"
      data-mos-delay="0.5"
      data-mos-anchor="#hero-main"
    >
      <Button
        variant="accent"
        href="https://app.getuku.com/signup"
        size="lg"
        class="min-w-[200px] font-bold shadow-lg"
      >
        Try for FREE
      </Button>
      <Button
        variant="secondary"
        href="https://getuku.com/book-demo"
        size="lg"
        class="min-w-[160px] shadow-md"
      >
        Book a Demo
      </Button>
    </div>

    <!-- Video link (no play button on image) -->
    <div
      class="mt-6"
      data-mos="fade-up"
      data-mos-delay="0.6"
      data-mos-anchor="#hero-main"
    >
      <a
        href="https://www.youtube.com/watch?v=wd9wCOR6tRs"
        target="_blank"
        rel="noopener noreferrer"
        class="text-secondary-600 hover:text-secondary-700 dark:text-secondary-400 dark:hover:text-secondary-300 inline-flex items-center gap-2 text-sm font-medium transition"
      >
        <Icon name="tabler/player-play" class="h-4 w-4" aria-hidden="true" />
        <span>See how Uku works</span>
      </a>
    </div>
  </div>

  <!-- Hero dashboard image - NO PLAY BUTTON, sharp quality -->
  <div
    class="site-container absolute inset-0 top-3/4 z-10 mx-auto max-w-7xl sm:top-2/3 md:top-[55%]"
    aria-hidden="true"
  >
    <div
      class="relative h-fit overflow-hidden rounded-2xl shadow-2xl shadow-secondary-500/20"
      data-mos="fade-in"
      data-mos-delay="0.3"
      data-mos-anchor="#hero-main"
    >
      <Image
        src={heroDashboard}
        alt="Uku Dashboard - Accounting Practice Management Software"
        loading="eager"
        width={1800}
        quality={100}
        class="w-full"
      />
    </div>
  </div>
</section>
