---
import { getRelativeLocaleUrl } from "astro:i18n";

// utils
import { slugify, categorify, humanize } from "@js/textUtils";
import { getLocaleFromUrl } from "@js/localeUtils";

interface Props {
	category: string | undefined;
	class?: string;
}

const { category, class: classList } = Astro.props as Props;

const currLocale = getLocaleFromUrl(Astro.url);
---

{
	category && (
		<a
			href={getRelativeLocaleUrl(currLocale, `/categories/${slugify(category)}/`)}
			class:list={[
				"rounded-full bg-base-200 px-2 py-0.5 font-medium transition hover:text-primary-600 dark:bg-base-900 dark:hover:text-primary-400",
				classList,
			]}
		>
			{humanize(category)}
		</a>
	)
}
